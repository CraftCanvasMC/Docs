---

interface Props {
  name: string;
}

const { name } = Astro.props;
const href = `https://minecraft.wiki/w/Commands/${name}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="wcb"
  aria-label={`Open wiki page for /${name}`}
><span class="wcb-slash" aria-hidden="true">/</span>{name}<span class="wcb-arrow" aria-hidden="true">↗</span></a>

<style>
  .wcb {
    display: inline-flex;
    align-items: center;
    gap: 0.15em;
    padding: 0.1em 0.5em;
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.82em;
    color: var(--sl-color-accent-high);
    background-color: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-accent-low);
    border-radius: 0.3em;
    text-decoration: none;
    white-space: nowrap;
    vertical-align: middle;
    line-height: 1.6;
    transition:
      background-color 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
  }

  .wcb:hover {
    background-color: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
    color: var(--sl-color-black);
  }

  .wcb-slash {
    color: var(--sl-color-accent);
    opacity: 0.7;
    font-size: 0.9em;
  }

  .wcb:hover .wcb-slash {
    color: inherit;
    opacity: 1;
  }

  .wcb-arrow {
    font-size: 0.85em;
    transition: transform 0.15s ease;
  }

  .wcb:hover .wcb-arrow {
    transform: translate(1px, -1px);
  }
</style>
